APP_NAME=Local Knowledge Base
DATABASE_PATH=./data/knowledge_base.db
UPLOAD_DIR=./data/uploads

# 导入去重（同项目、同文件字节指纹）：ignore | overwrite | keep
# IMPORT_DEDUP_MODE=ignore

# 检索融合权重（向量 / BM25 / 简单词面重合，总和建议为 1）
# RETRIEVAL_VECTOR_WEIGHT=0.52
# RETRIEVAL_BM25_WEIGHT=0.38
# RETRIEVAL_KEYWORD_WEIGHT=0.10

# RAG：低于该融合分时不调 LLM（避免胡编）
# RAG_MIN_EVIDENCE_SCORE=0.14

# OCR（扫描 PDF / 图片，需本机 Tesseract + uv sync --extra ocr）
# OCR_ENABLED=false
# OCR_LANG=chi_sim+eng
# OCR_TESSERACT_CMD=
# OCR_PDF_MIN_TEXT_CHARS=80
# OCR_PDF_MAX_PAGES=30
# OCR_PDF_DPI=300
# 文字层疑似乱码时强制按页 OCR（与 OCR_ENABLED 同时开启）
# OCR_PDF_FORCE_VISUAL=false
# 文字层够长但 CJK 占比低于该值时改走 OCR（0 表示关闭；纯英文 PDF 勿设或改用 eng）
# OCR_PDF_MIN_CJK_RATIO=0
# Tesseract 额外参数，例如单栏正文可试 --psm 6
# OCR_TESSERACT_CONFIG=
# OCR_PREPROCESS_AUTOCONTRAST=true

# 开发验证可使用 hash；正式语义检索建议使用 sentence_transformers
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://127.0.0.1:8642/v1
LLM_API_KEY=change-me-local-dev
LLM_MODEL=hermes-agent
LLM_TIMEOUT_SECONDS=120
